@model RehearsalHub.Web.ViewModels.ErrorViewModel
@{
    ViewData["Title"] = $"{Model.StatusCode} - {Model.Title}";
}

@section Styles {
    <style>
        .error-hero {
            min-height: 72vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem 1rem;
        }

        .error-glass {
            background: rgba(18, 18, 18, 0.75);
            border: 1px solid rgba(255, 69, 0, 0.25);
            border-radius: 20px;
            padding: 3rem 2.5rem;
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            max-width: 560px;
            width: 100%;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(255, 255, 255, 0.04) inset;
        }

        .error-icon-ring {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            background: rgba(255, 69, 0, 0.1);
            border: 2px solid rgba(255, 69, 0, 0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.6rem;
            font-size: 2.1rem;
            color: var(--band-orange);
            animation: pulseRing 3s ease-in-out infinite;
        }

        @@keyframes pulseRing {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(255, 69, 0, 0.3);
            }

            50% {
                box-shadow: 0 0 0 10px rgba(255, 69, 0, 0);
            }
        }

        .error-code {
            font-size: clamp(5rem, 16vw, 9rem);
            font-weight: 900;
            line-height: 1;
            background: var(--band-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            user-select: none;
            letter-spacing: -3px;
        }

        .error-divider {
            width: 52px;
            height: 3px;
            background: var(--band-gradient);
            border-radius: 2px;
            margin: 1rem auto 1.4rem;
        }

        .error-title {
            color: #ffffff;
            font-weight: 700;
            font-size: 1.4rem;
            margin-bottom: .65rem;
        }

        .error-message {
            color: rgba(255, 255, 255, 0.6);
            font-size: .97rem;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        .error-request-id {
            font-size: .75rem;
            color: rgba(255, 255, 255, 0.25);
            font-family: monospace;
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.07);
        }

        .btn-error-primary {
            background: var(--band-gradient);
            background-size: 200% auto;
            color: #fff;
            border: none;
            padding: .65rem 1.8rem;
            border-radius: 8px;
            font-weight: 700;
            text-decoration: none;
            transition: background-position .3s, transform .15s;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            font-size: .95rem;
        }

            .btn-error-primary:hover {
                background-position: right center;
                color: #fff;
                transform: translateY(-2px);
            }

        .btn-error-secondary {
            background: transparent;
            color: rgba(255, 255, 255, 0.55);
            border: 1px solid rgba(255, 255, 255, 0.15);
            padding: .65rem 1.5rem;
            border-radius: 8px;
            font-weight: 500;
            text-decoration: none;
            transition: border-color .15s, color .15s, transform .15s;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            font-size: .95rem;
            cursor: pointer;
        }

            .btn-error-secondary:hover {
                border-color: var(--band-orange);
                color: var(--band-orange);
                transform: translateY(-2px);
            }

        .quick-links {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: .5rem;
            margin-top: 1.8rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.07);
        }

        .quick-link {
            font-size: .8rem;
            color: rgba(255, 255, 255, 0.35);
            text-decoration: none;
            transition: color .15s;
            display: inline-flex;
            align-items: center;
            gap: .3rem;
        }

            .quick-link:hover {
                color: var(--band-orange);
            }

        .quick-link-sep {
            color: rgba(255, 255, 255, 0.15);
            font-size: .8rem;
        }
    </style>
}

<div class="error-hero">
    <div class="error-glass text-center">

        <div class="error-icon-ring">
            <i class="@Model.IconClass"></i>
        </div>

        <div class="error-code">@Model.StatusCode</div>

        <div class="error-divider"></div>

        <h1 class="error-title">@Model.Title</h1>
        <p class="error-message">@Model.Message</p>

        <div class="d-flex flex-wrap justify-content-center gap-3">

            @if (Model.StatusCode == 401)
            {
                <a asp-area="Identity" asp-page="/Account/Login"
                   class="btn-error-primary">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    Sign In
                </a>
            }
            else
            {
                <a asp-controller="Home" asp-action="Index"
                   class="btn-error-primary">
                    <i class="fa-solid fa-house"></i>
                    Go Home
                </a>
            }

            @if (Model.ShowBackButton)
            {
                <button onclick="history.back()" class="btn-error-secondary">
                    <i class="fa-solid fa-arrow-left"></i>
                    Go Back
                </button>
            }

        </div>

        <nav class="quick-links" aria-label="Quick navigation">
            <a asp-controller="Bands" asp-action="Index" class="quick-link">
                <i class="fa-solid fa-guitar fa-xs"></i> My Bands
            </a>
            <span class="quick-link-sep">·</span>
            <a asp-controller="Rehearsals" asp-action="Index" class="quick-link">
                <i class="fa-solid fa-calendar fa-xs"></i> Rehearsals
            </a>
            <span class="quick-link-sep">·</span>
            <a asp-controller="Songs" asp-action="Index" class="quick-link">
                <i class="fa-solid fa-music fa-xs"></i> Songs
            </a>
            <span class="quick-link-sep">·</span>
            <a asp-controller="Home" asp-action="Privacy" class="quick-link">
                <i class="fa-solid fa-shield fa-xs"></i> Privacy
            </a>
        </nav>

        @if (Model.ShowRequestId)
        {
            <div class="error-request-id">
                Request ID: <code>@Model.RequestId</code>
            </div>
        }

    </div>
</div>
