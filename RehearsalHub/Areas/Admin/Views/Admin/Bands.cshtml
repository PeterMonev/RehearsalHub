@using RehearsalHub.GCommon
@using RehearsalHub.Web.ViewModels.Admin
@model PagedResult<AdminBandViewModel>
@{
    ViewData["Title"] = "Manage Bands";
    string? currentSearch = ViewData["CurrentSearch"]?.ToString();
}

<div class="container py-4 animate-fade-in">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 border-bottom border-secondary pb-4">
        <div>
            <h1 class="display-5 fw-bold mb-1">
                <i class="fa-solid fa-guitar text-danger me-2"></i>Manage Bands
            </h1>
            <p class="text-muted mb-0">@Model.TotalItems bands on the platform</p>
        </div>
        <a asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 mt-3 mt-md-0">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>

    <div class="mb-4 shadow-sm rounded-4 rounded-pill overflow-hidden">
        <form asp-area="Admin" asp-action="Bands" method="get" class="d-flex gap-2 p-3 bg-dark">
            <input type="text" name="searchTerm" value="@currentSearch"
                   class="form-control bg-dark text-white border-secondary rounded-pill"
                   placeholder="Search by band name..." />
            <button type="submit" class="btn btn-gradient rounded-pill  text-warning px-4 fw-bold">
                <i class="fa-solid fa-search me-1"></i>Search
            </button>
            @if (!string.IsNullOrEmpty(currentSearch))
            {
                <a asp-area="Admin" asp-action="Bands" class="btn btn-outline-secondary rounded-pill px-3">
                    <i class="fa-solid fa-xmark"></i>
                </a>
            }
        </form>
    </div>

    <div class="card bg-dark text-white border-0 rounded-4 shadow-lg rounded-pill  overflow-hidden mb-4">

        <div class="table-responsive d-none d-md-block">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr class="border-bottom border-secondary">
                        <th class="ps-4 py-3">Band</th>
                        <th class="py-3">Owner</th>
                        <th class="py-3 text-center">Genre</th>
                        <th class="py-3 text-center">Members</th>
                        <th class="py-3 text-center">Rehearsals</th>
                        <th class="py-3 text-center">Created</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var band in Model.Items)
                    {
                        <tr class="border-bottom border-secondary border-opacity-25">
                            <td class="ps-4 py-3 fw-bold">@band.Name</td>
                            <td class="text-muted small">
                                <i class="fa-solid fa-crown text-warning me-1"></i>@band.OwnerName
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary rounded-pill px-3">@band.Genre</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary rounded-pill">@band.MemberCount</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary rounded-pill">@band.RehearsalCount</span>
                            </td>
                            <td class="text-center text-muted small">@band.CreatedOn.ToString("dd MMM yyyy")</td>
                            <td class="text-end pe-4">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a asp-area="Admin" asp-action="EditBand" asp-route-id="@band.Id"
                                       class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                        <i class="fa-solid fa-pen me-1"></i>Edit
                                    </a>
                                    <form asp-area="Admin" asp-action="DeleteBand" asp-route-id="@band.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 btn-delete-confirm"
                                                data-title="Delete band?"
                                                data-message="This will permanently delete &quot;@band.Name&quot; and all its rehearsals and setlists.">
                                            <i class="fa-solid fa-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-guitar fa-2x mb-3 d-block opacity-25"></i>No bands found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-md-none p-3">
            @foreach (var band in Model.Items)
            {
                <div class="mobile-card mb-3 rounded-4 p-3 border border-secondary border-opacity-25">
                    <div class="d-flex align-items-start justify-content-between mb-2">
                        <div>
                            <div class="fw-bold fs-6">@band.Name</div>
                            <div class="text-muted small">
                                <i class="fa-solid fa-crown text-warning me-1"></i>@band.OwnerName
                            </div>
                        </div>
                        <span class="badge bg-secondary rounded-pill px-2">@band.Genre</span>
                    </div>
                    <div class="d-flex gap-3 text-muted small mb-3">
                        <span><i class="fa-solid fa-users me-1"></i>@band.MemberCount members</span>
                        <span><i class="fa-solid fa-calendar me-1"></i>@band.RehearsalCount rehearsals</span>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-area="Admin" asp-action="EditBand" asp-route-id="@band.Id"
                           class="btn btn-sm btn-outline-warning rounded-pill px-3">
                            <i class="fa-solid fa-pen me-1"></i>Edit
                        </a>
                        <form asp-area="Admin" asp-action="DeleteBand" asp-route-id="@band.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 btn-delete-confirm"
                                    data-title="Delete band?"
                                    data-message="This will permanently delete &quot;@band.Name&quot;.">
                                <i class="fa-solid fa-trash me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                </div>
            }
            @if (!Model.Items.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fa-solid fa-guitar fa-2x mb-3 d-block opacity-25"></i>No bands found.
                </div>
            }
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="d-flex justify-content-center">
            <ul class="pagination shadow-lg rounded-pill overflow-hidden border-0">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-0 px-4 py-2"
                       asp-area="Admin" asp-action="Bands"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-searchTerm="@currentSearch">
                        <i class="fa fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link border-0 px-3 py-2 @(i == Model.CurrentPage ? "btn-gradient text-white" : "bg-dark text-white")"
                           asp-area="Admin" asp-action="Bands"
                           asp-route-page="@i"
                           asp-route-searchTerm="@currentSearch">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-0 px-4 py-2"
                       asp-area="Admin" asp-action="Bands"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-searchTerm="@currentSearch">
                        <i class="fa fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Styles {
    <style>
        .mobile-card {
            background: rgba(255,255,255,.04);
        }

        .pagination .page-link:hover {
            background-color: var(--band-orange) !important;
            color: white !important;
        }
    </style>
}
