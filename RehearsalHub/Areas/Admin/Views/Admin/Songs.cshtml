@using RehearsalHub.GCommon
@using RehearsalHub.Web.ViewModels.Admin
@model PagedResult<AdminSongViewModel>
@{
    ViewData["Title"] = "Manage Songs";
    string? currentSearch = ViewData["CurrentSearch"]?.ToString();
}

<div class="container py-4 animate-fade-in">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 border-bottom border-secondary pb-4">
        <div>
            <h1 class="display-5 fw-bold mb-1">
                <i class="fa-solid fa-music text-danger me-2"></i>Manage Songs
            </h1>
            <p class="text-muted mb-0">
                @Model.TotalItems songs in the system
                <span class="ms-2 badge bg-secondary">Public &amp; Private</span>
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 mt-3 mt-md-0">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>

    <div class="mb-4 shadow-sm rounded-4 overflow-hidden">
        <form asp-action="Songs" method="get" class="d-flex gap-2 p-3 bg-dark">
            <input type="text"
                   name="searchTerm"
                   value="@currentSearch"
                   class="form-control bg-dark text-white border-secondary rounded-pill"
                   placeholder="Search by title or artist..." />
            <button type="submit" class="btn btn-gradient rounded-pill px-4 fw-bold">
                <i class="fa-solid fa-search me-1"></i>Search
            </button>
            @if (!string.IsNullOrEmpty(currentSearch))
            {
                <a asp-action="Songs" class="btn btn-outline-secondary rounded-pill px-3">
                    <i class="fa-solid fa-xmark"></i>
                </a>
            }
        </form>
    </div>

    <div class="card bg-dark text-white border-0 rounded-4 shadow-lg overflow-hidden mb-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr class="border-bottom border-secondary">
                        <th class="ps-4 py-3">Title</th>
                        <th class="py-3">Artist</th>
                        <th class="py-3 text-center">Genre</th>
                        <th class="py-3 text-center">Key</th>
                        <th class="py-3 text-center">Tempo</th>
                        <th class="py-3 text-center">Visibility</th>
                        <th class="py-3">Creator</th>
                        <th class="py-3">Band</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var song in Model.Items)
                    {
                        <tr class="border-bottom border-secondary border-opacity-25">
                            <td class="ps-4 py-3">
                                <span class="fw-bold">@song.Title</span>
                                <div class="text-muted" style="font-size:.75rem">@song.Duration</div>
                            </td>
                            <td class="text-muted small">@song.Artist</td>
                            <td class="text-center">
                                <span class="badge bg-secondary rounded-pill px-3">@song.Genre</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary rounded-pill">@song.MusicalKey</span>
                            </td>
                            <td class="text-center text-muted small">@song.TempoDisplay</td>
                            <td class="text-center">
                                @if (song.IsPrivate)
                                {
                                    <span class="badge badge-private rounded-pill px-3 py-2">
                                        <i class="fa-solid fa-lock me-1"></i>Private
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-public rounded-pill px-3 py-2">
                                        <i class="fa-solid fa-globe me-1"></i>Public
                                    </span>
                                }
                            </td>
                            <td class="text-muted small">
                                <i class="fa-solid fa-user me-1 opacity-50"></i>@song.CreatorName
                            </td>
                            <td class="text-muted small">
                                @if (!string.IsNullOrEmpty(song.OwnerBandName))
                                {
                                    <i class="fa-solid fa-guitar me-1 opacity-50"></i>
                                    @song.OwnerBandName
                                }
                                else
                                {
                                    <span class="opacity-25">—</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <form asp-action="DeleteSong" asp-route-id="@song.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger rounded-pill px-3 btn-delete-confirm"
                                            data-title="Delete song?"
                                            data-message="This will permanently delete &quot;@song.Title&quot; by @song.Artist from the entire system.">
                                        <i class="fa-solid fa-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }

                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-music fa-2x mb-3 d-block opacity-25"></i>
                                No songs found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Songs pagination" class="d-flex justify-content-center">
            <ul class="pagination shadow-lg rounded-pill overflow-hidden border-0">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-0 px-4 py-2"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-searchTerm="@currentSearch">
                        <i class="fa fa-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link border-0 px-3 py-2 @(i == Model.CurrentPage ? "btn-gradient text-white" : "bg-dark text-white")"
                           asp-route-page="@i"
                           asp-route-searchTerm="@currentSearch">@i</a>
                    </li>
                }
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-0 px-4 py-2"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-searchTerm="@currentSearch">
                        <i class="fa fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }

</div>

@section Styles {
    <style>
        .badge-private {
            background: rgba(220, 53, 69, 0.15);
            color: #dc3545;
            border: 1px solid rgba(220, 53, 69, 0.3);
        }

        .badge-public {
            background: rgba(25, 135, 84, 0.15);
            color: #198754;
            border: 1px solid rgba(25, 135, 84, 0.3);
        }

        .pagination .page-link:hover {
            background-color: var(--band-orange) !important;
            color: white !important;
        }
    </style>
}
